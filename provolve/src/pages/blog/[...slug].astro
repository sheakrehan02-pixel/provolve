---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title={post.data.title} description={post.data.description} canonicalURL={`https://provolve.net/blog/${post.slug}/`}>
  <article class="article-editorial" data-page="post">
    <nav class="article-nav">
      <a href="/" class="article-back link-underline">
        <span aria-hidden="true">←</span> Back to all articles
      </a>
    </nav>

    <header class="article-header">
      <time class="article-date" datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </time>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="article-description">{post.data.description}</p>
      )}
      <div class="article-header-divider" aria-hidden="true"></div>
    </header>

    {post.data.heroImage && (
      <figure class="article-hero">
        <img src={post.data.heroImage} alt="" />
      </figure>
    )}

    <div class="article-body">
      <div class="blog-content prose">
        <Content />
      </div>
    </div>

    <div class="article-end-divider" aria-hidden="true"></div>

    <footer class="article-footer">
      {relatedPosts.length > 0 && (
        <div class="article-related">
          <h2 class="article-related-title">More articles</h2>
          <ul class="article-related-list">
            {relatedPosts.map((p) => (
              <li>
                <a href={`/blog/${p.slug}/`} class="link-underline">{p.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
      <a href="/" class="article-back link-underline">
        <span aria-hidden="true">←</span> Back to all posts
      </a>
    </footer>
  </article>

  <style>
    /* —— Article container: max 720px, warm spacing —— */
    .article-editorial {
      max-width: 720px;
      margin: 0 auto;
      padding-bottom: 4rem;
    }

    .article-nav {
      margin-bottom: 2.5rem;
    }

    .article-back {
      font-size: 0.9375rem;
      font-weight: 500;
      color: rgba(56, 36, 13, 0.65);
      transition: color 0.2s ease;
    }
    .article-back:hover {
      color: #C05800;
    }

    /* —— Header: H1 bold, large, spacious —— */
    .article-header {
      margin-bottom: 3.5rem;
    }

    .article-date {
      display: block;
      font-size: 0.8125rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(56, 36, 13, 0.55);
      margin-bottom: 1rem;
    }

    .article-title {
      font-family: var(--font-serif, 'Cormorant Garamond', Georgia, serif);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.18;
      letter-spacing: -0.01em;
      color: #38240D;
      margin: 0 0 1.25rem;
      max-width: 20ch;
    }

    .article-description {
      font-size: 1.1875rem;
      line-height: 1.65;
      color: rgba(56, 36, 13, 0.82);
      margin: 0;
      max-width: 50ch;
    }

    .article-header-divider {
      margin-top: 2.5rem;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(113, 54, 0, 0.18), transparent);
    }

    .article-hero {
      margin: 0 0 3rem;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(113, 54, 0, 0.1);
    }
    .article-hero img {
      width: 100%;
      height: auto;
      display: block;
    }

    .article-body {
      position: relative;
    }

    /* —— Prose: 680px max, line-height 1.65–1.75, rhythm —— */
    .prose {
      max-width: 680px;
      font-size: 1.0625rem;
      line-height: 1.72;
      letter-spacing: 0.015em;
      color: rgba(56, 36, 13, 0.88);
    }

    .prose p {
      margin: 0 0 1.75rem;
      word-spacing: 0.01em;
    }
    .prose p:last-child {
      margin-bottom: 0;
    }

    /* Lead paragraph + drop cap */
    .prose > p:first-of-type {
      font-size: 1.1875rem;
      line-height: 1.7;
      color: rgba(56, 36, 13, 0.92);
      margin-bottom: 2rem;
    }

    .prose > p:first-of-type::first-letter {
      font-family: var(--font-serif);
      font-size: 4.25rem;
      line-height: 1;
      font-weight: 600;
      float: left;
      margin: 0.06em 0.1em 0 -0.02em;
      color: #713600;
    }

    /* —— Section spacing: 80–120px between major sections —— */
    .prose h2 {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      color: #38240D;
      margin: 5rem 0 1.25rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid rgba(192, 88, 0, 0.22);
      transition: color 0.2s ease;
    }
    .prose h2:first-of-type {
      margin-top: 0;
    }
    .prose h2:hover {
      color: #713600;
    }

    .prose h3 {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 600;
      color: #38240D;
      margin: 2.5rem 0 0.75rem;
      transition: color 0.2s ease;
    }
    .prose h3:hover {
      color: rgba(113, 54, 0, 0.9);
    }

    /* Section separator after each h2 block (optional visual break) */
    .prose h2 + p {
      margin-top: 1.25rem;
    }

    .prose strong {
      font-weight: 600;
      color: #38240D;
    }

    .prose a {
      color: #C05800;
      font-weight: 500;
      text-decoration: none;
      border-bottom: 1px solid rgba(192, 88, 0, 0.35);
      transition: color 0.2s ease, border-color 0.2s ease;
    }
    .prose a:hover {
      color: #713600;
      border-bottom-color: #713600;
    }

    /* —— Quote formatting: larger, indented, soft bg, italic, left accent —— */
    .prose blockquote {
      margin: 2.5rem 0;
      padding: 1.5rem 0 1.5rem 1.75rem;
      border-left: 4px solid #C05800;
      background: rgba(192, 88, 0, 0.06);
      font-style: italic;
      font-size: 1.0625rem;
      line-height: 1.75;
      letter-spacing: 0.01em;
      color: rgba(56, 36, 13, 0.85);
      border-radius: 0 8px 8px 0;
    }

    /* Question-quote list (use class="question-quotes" on a wrapper in content) */
    .prose .question-quotes {
      margin: 2rem 0;
      padding: 1.5rem 0 1.5rem 1.5rem;
      border-left: 4px solid rgba(192, 88, 0, 0.5);
      background: rgba(192, 88, 0, 0.05);
      border-radius: 0 8px 8px 0;
    }
    .prose .question-quotes ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .prose .question-quotes li {
      font-size: 1.0625rem;
      line-height: 1.7;
      color: rgba(56, 36, 13, 0.88);
      margin-bottom: 0.85rem;
      padding-left: 1.25rem;
      position: relative;
      font-style: italic;
    }
    .prose .question-quotes li:last-child {
      margin-bottom: 0;
    }
    .prose .question-quotes li::before {
      content: '"';
      position: absolute;
      left: 0;
      color: rgba(192, 88, 0, 0.5);
      font-family: var(--font-serif);
      font-size: 1.25em;
    }

    /* —— Lists: better vertical spacing, clear bullets —— */
    .prose ul,
    .prose ol {
      margin: 2rem 0;
      padding-left: 1.5rem;
      letter-spacing: 0.01em;
    }

    .prose li {
      margin-bottom: 0.65rem;
      line-height: 1.75;
      padding-left: 0.35rem;
    }
    .prose li + li {
      margin-top: 0.25rem;
    }

    .prose ul li::marker {
      color: #C05800;
      font-size: 0.85em;
    }

    /* Mobile: reduce section spacing for smaller viewports */
    @media (max-width: 640px) {
      .article-title {
        max-width: none;
      }
      .prose h2 {
        margin-top: 3.5rem;
      }
      .prose h3 {
        margin-top: 2rem;
      }
    }

    .prose hr {
      margin: 3rem 0;
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(113, 54, 0, 0.12), transparent);
    }

    .prose code {
      background: rgba(192, 88, 0, 0.1);
      color: #C05800;
      padding: 0.2em 0.45em;
      border-radius: 4px;
      font-size: 0.9em;
    }

    /* Diagrams & callouts */
    .prose .article-diagram {
      margin: 2.75rem 0;
      padding: 1.5rem;
      background: rgba(113, 54, 0, 0.04);
      border: 1px solid rgba(113, 54, 0, 0.1);
      border-radius: 12px;
    }
    .prose .article-diagram figcaption {
      font-size: 0.875rem;
      color: rgba(56, 36, 13, 0.65);
      margin-top: 1rem;
      text-align: center;
      letter-spacing: 0.02em;
      line-height: 1.5;
    }

    .prose .callout {
      margin: 2.5rem 0;
      padding: 1.5rem 1.75rem;
      background: rgba(192, 88, 0, 0.06);
      border-left: 4px solid #C05800;
      border-radius: 0 8px 8px 0;
      font-size: 1.03125rem;
      line-height: 1.72;
      letter-spacing: 0.012em;
    }

    .article-end-divider {
      margin: 3.5rem 0 2rem;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(113, 54, 0, 0.15), transparent);
    }

    .article-footer {
      padding-top: 0.5rem;
    }

    .article-related {
      margin-bottom: 2rem;
    }

    .article-related-title {
      font-family: var(--font-serif);
      font-size: 1.125rem;
      font-weight: 600;
      color: #38240D;
      margin: 0 0 1rem;
    }

    .article-related-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .article-related-list li {
      margin-bottom: 0.5rem;
    }
    .article-related-list a {
      font-weight: 500;
      color: rgba(56, 36, 13, 0.82);
      transition: color 0.2s ease;
    }
    .article-related-list a:hover {
      color: #C05800;
    }

    /* Subtle fade-in on load (respect reduced motion) */
    @media (prefers-reduced-motion: no-preference) {
      .prose > * {
        animation: editorialFadeIn 0.5s ease-out both;
      }
      .prose > *:nth-child(1) { animation-delay: 0.05s; }
      .prose > *:nth-child(2) { animation-delay: 0.08s; }
      .prose > *:nth-child(3) { animation-delay: 0.11s; }
      .prose > *:nth-child(4) { animation-delay: 0.14s; }
      .prose > *:nth-child(5) { animation-delay: 0.17s; }
      .prose > *:nth-child(n+6) { animation-delay: 0.2s; }
    }
    @keyframes editorialFadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</Layout>
