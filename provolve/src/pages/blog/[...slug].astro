---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title={post.data.title} description={post.data.description} canonicalURL={`https://provolve.net/blog/${post.slug}/`}>
  <article class="article-post">
    <a href="/" class="article-back link-underline">← Back to all articles</a>

    <header class="article-header">
      <time class="article-date" datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </time>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.description && <p class="article-description">{post.data.description}</p>}
    </header>

    {post.data.heroImage && (
      <figure class="article-hero">
        <img src={post.data.heroImage} alt="" />
      </figure>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer class="article-footer">
      {relatedPosts.length > 0 && (
        <div class="article-related">
          <h2 class="article-related-title">More articles</h2>
          <ul class="article-related-list">
            {relatedPosts.map((p) => (
              <li><a href={`/blog/${p.slug}/`} class="link-underline">{p.data.title}</a></li>
            ))}
          </ul>
        </div>
      )}
      <a href="/" class="article-back link-underline">← Back to all posts</a>
    </footer>
  </article>

  <style>
    .article-post {
      max-width: 720px;
      margin: 0 auto;
      padding-bottom: 3rem;
    }

    .article-back {
      display: inline-block;
      font-size: 0.9375rem;
      font-weight: 500;
      color: rgba(56, 36, 13, 0.65);
      margin-bottom: 2rem;
    }
    .article-back:hover { color: #C05800; }

    .article-header { margin-bottom: 2.5rem; }

    .article-date {
      display: block;
      font-size: 0.8125rem;
      color: rgba(56, 36, 13, 0.55);
      margin-bottom: 0.5rem;
    }

    .article-title {
      font-family: var(--font-serif, 'Cormorant Garamond', Georgia, serif);
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.25;
      color: #38240D;
      margin: 0 0 0.75rem;
    }

    .article-description {
      font-size: 1.125rem;
      line-height: 1.6;
      color: rgba(56, 36, 13, 0.82);
      margin: 0;
    }

    .article-hero {
      margin: 0 0 2rem;
      border-radius: 8px;
      overflow: hidden;
    }
    .article-hero img { width: 100%; height: auto; display: block; }

    .prose {
      font-size: 1.0625rem;
      line-height: 1.7;
      color: rgba(56, 36, 13, 0.88);
    }

    .prose p { margin: 0 0 1.25rem; }
    .prose p:last-child { margin-bottom: 0; }

    .prose > p:first-of-type::first-letter {
      font-family: var(--font-serif);
      font-size: 3.5rem;
      line-height: 1;
      font-weight: 600;
      float: left;
      margin: 0.05em 0.08em 0 -0.02em;
      color: #713600;
    }

    .prose h2 {
      font-family: var(--font-serif);
      font-size: 1.375rem;
      font-weight: 600;
      color: #38240D;
      margin: 2.5rem 0 0.75rem;
      padding-top: 1.5rem;
      padding-bottom: 0.4rem;
      border-top: 1px solid rgba(113, 54, 0, 0.2);
      border-bottom: 1px solid rgba(192, 88, 0, 0.25);
    }
    .prose h2:first-of-type { margin-top: 0; padding-top: 0; border-top: none; }

    .prose h3 {
      font-family: var(--font-serif);
      font-size: 1.125rem;
      font-weight: 600;
      color: #38240D;
      margin: 1.5rem 0 0.5rem;
    }

    .prose strong { font-weight: 600; color: #38240D; }

    .prose a {
      color: #C05800;
      font-weight: 500;
      text-decoration: none;
      border-bottom: 1px solid rgba(192, 88, 0, 0.35);
    }
    .prose a:hover { color: #713600; border-bottom-color: #713600; }

    .prose blockquote {
      margin: 1.5rem 0;
      padding: 1rem 0 1rem 1.25rem;
      border-left: 3px solid #C05800;
      background: rgba(192, 88, 0, 0.06);
      font-style: italic;
      color: rgba(56, 36, 13, 0.85);
    }

    .prose ul, .prose ol { margin: 1.25rem 0; padding-left: 1.5rem; }
    .prose li { margin-bottom: 0.35rem; line-height: 1.65; }
    .prose ul li::marker { color: #C05800; }

    .prose hr {
      margin: 2rem 0;
      border: none;
      height: 1px;
      background: rgba(113, 54, 0, 0.15);
    }

    .prose code {
      background: rgba(192, 88, 0, 0.1);
      color: #C05800;
      padding: 0.15em 0.35em;
      border-radius: 4px;
      font-size: 0.9em;
    }

    .prose .article-diagram {
      margin: 2rem 0;
      padding: 1.5rem;
      background: rgba(113, 54, 0, 0.04);
      border: 1px solid rgba(113, 54, 0, 0.12);
      border-radius: 8px;
      width: 100%;
      box-sizing: border-box;
    }
    .prose .article-diagram svg {
      display: block;
      width: 100%;
      max-width: 100%;
      height: auto;
      margin: 0 auto;
    }
    .prose .article-diagram figcaption {
      font-size: 0.8125rem;
      color: rgba(56, 36, 13, 0.65);
      margin-top: 1rem;
      padding-top: 0;
      line-height: 1.5;
      text-align: left;
      max-width: 100%;
    }

    .prose .callout {
      margin: 1.5rem 0;
      padding: 1.25rem 1.5rem;
      background: rgba(192, 88, 0, 0.06);
      border-left: 3px solid #C05800;
      border-radius: 0 6px 6px 0;
    }

    .article-footer { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(113, 54, 0, 0.1); }

    .article-related-title {
      font-family: var(--font-serif);
      font-size: 1.0625rem;
      font-weight: 600;
      color: #38240D;
      margin: 0 0 0.75rem;
    }

    .article-related-list { list-style: none; padding: 0; margin: 0 0 1.5rem; }
    .article-related-list li { margin-bottom: 0.5rem; }
    .article-related-list a { font-weight: 500; color: rgba(56, 36, 13, 0.82); }
    .article-related-list a:hover { color: #C05800; }
  </style>
</Layout>
