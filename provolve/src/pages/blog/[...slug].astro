---
import { getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import Layout from '../../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { getPostNumber } from '../../utils/postHelpers';
import '../../styles/editorial.css';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const allPosts = await getCollection('blog');
const postNumber = getPostNumber(post, allPosts);

const processor = await createMarkdownProcessor();
const bodyHtml = (await processor.render(post.body)).code;

const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonicalURL={`https://provolve.net/blog/${post.slug}/`}
  variant="editorial"
>
  <article class="editorial-article">
    <a href="/" class="editorial-back">← All posts</a>

    <div class="editorial-masthead">
      <span class="editorial-masthead-label">Provolve blog</span>
      <span class="editorial-masthead-number">#{postNumber}</span>
    </div>

    <header class="editorial-header">
      <time class="editorial-date" datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </time>
      <h1 class="editorial-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="editorial-dek">{post.data.description}</p>
      )}
    </header>

    {post.data.heroImage && (
      <figure class="editorial-hero">
        <img src={post.data.heroImage} alt="" />
      </figure>
    )}

    <div class="editorial-prose" set:html={bodyHtml} />

    <footer class="editorial-footer">
      {relatedPosts.length > 0 && (
        <>
          <h2 class="editorial-related-title">More articles</h2>
          <ul class="editorial-related-list">
            {relatedPosts.map((p) => (
              <li><a href={`/blog/${p.slug}/`}>{p.data.title}</a></li>
            ))}
          </ul>
        </>
      )}
      <p class="editorial-handle">@provolve.net</p>
    </footer>
  </article>
</Layout>
